{
  "indent_size": 2,
  "indent_char": " ",
  "indent_with_tabs": false,
  "wrap_line_length": 120,
  "preserve_newlines": true,
  "max_preserve_newlines": 2,
  "end_with_newline": true,
  "wrap_attributes": "auto",
  "wrap_attributes_indent_size": 2,
  "unformatted": [],
  "content_unformatted": [
    "pre",
    "textarea",
    "code"
  ],
  "indent_inner_html": false,
  "extra_liners": [
    "head",
    "body",
    "/html"
  ]
}
